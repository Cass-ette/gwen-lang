{
  "Function": {
    "prefix": "func",
    "description": "Function definition",
    "body": [
      "func ${1:name}(${2:params})",
      "  ${3:body}",
      "endfunc"
    ]
  },
  "Function With Return": {
    "prefix": "funcr",
    "description": "Function definition with explicit return type",
    "body": [
      "func ${1:name}(${2:params}) -> ${3:return_type}",
      "  ${4:body}",
      "endfunc"
    ]
  },
  "If Statement": {
    "prefix": "if",
    "description": "If statement",
    "body": [
      "if ${1:condition} then",
      "  ${2:body}",
      "endif"
    ]
  },
  "If-Else": {
    "prefix": "ifelse",
    "description": "If-then-else statement",
    "body": [
      "if ${1:condition} then",
      "  ${2:true_body}",
      "else",
      "  ${3:false_body}",
      "endif"
    ]
  },
  "While Loop": {
    "prefix": "while",
    "description": "While loop",
    "body": [
      "while ${1:condition} do",
      "  ${2:body}",
      "endwhile"
    ]
  },
  "For Range": {
    "prefix": "for",
    "description": "For range loop",
    "body": [
      "for ${1:i} in ${2:start} to ${3:end} do",
      "  ${4:body}",
      "endfor"
    ]
  },
  "For Each": {
    "prefix": "foreach",
    "description": "For each loop",
    "body": [
      "for ${1:item} in ${2:list} do",
      "  ${3:body}",
      "endfor"
    ]
  },
  "Match Statement": {
    "prefix": "match",
    "description": "Pattern matching",
    "body": [
      "match ${1:subject}",
      "  when ${2:pattern1} =>",
      "    ${3:action1}",
      "  else",
      "    ${4:default_action}",
      "endmatch"
    ]
  },
  "Result Match": {
    "prefix": "matchr",
    "description": "Match on result with ok/err branches",
    "body": [
      "match ${1:result_value}",
      "  when ok(${2:value}) =>",
      "    ${3:handle_ok}",
      "  when err(${4:e}) =>",
      "    ${5:handle_err}",
      "endmatch"
    ]
  },
  "Module": {
    "prefix": "module",
    "description": "Module definition",
    "body": [
      "module ${1:name}",
      "  ${2:body}",
      "endmodule"
    ]
  },
  "Use From Module": {
    "prefix": "usefrom",
    "description": "Import names from a module",
    "body": [
      "use ${1:name} from ${2:module}"
    ]
  },
  "Use Module": {
    "prefix": "usemod",
    "description": "Import a module namespace",
    "body": [
      "use ${1:module}"
    ]
  },
  "Object": {
    "prefix": "object",
    "description": "Object definition with constructor",
    "body": [
      "object ${1:Name}",
      "  ${2:field}: ${3:type}",
      "",
      "  new(${4:value}: ${3:type}) -> ${1:Name}",
      "    return ${1:Name}{",
      "      ${2} := ${4}",
      "    }",
      "  endnew",
      "endobject"
    ]
  },
  "Export Object": {
    "prefix": "expobject",
    "description": "Exported object definition",
    "body": [
      "export object ${1:Name}",
      "  ${2:field}: ${3:type}",
      "",
      "  new(${4:value}: ${3:type}) -> ${1:Name}",
      "    return ${1:Name}{",
      "      ${2} := ${4}",
      "    }",
      "  endnew",
      "endobject"
    ]
  },
  "Type Alias": {
    "prefix": "type",
    "description": "Transparent type alias",
    "body": [
      "type ${1:Name} = ${2:int}"
    ]
  },
  "Const": {
    "prefix": "const",
    "description": "Immutable binding",
    "body": [
      "const ${1:NAME}: ${2:int} := ${3:value}"
    ]
  },
  "Variable Block": {
    "prefix": "var",
    "description": "Batch variable declarations",
    "body": [
      "var",
      "  ${1:name}: ${2:type} := ${3:value}",
      "endvar"
    ]
  },
  "Var Default": {
    "prefix": "vardefault",
    "description": "Variable block with shared default value",
    "body": [
      "var default ${1:0}",
      "  ${2:name}: ${3:int}",
      "endvar"
    ]
  },
  "Result Ok": {
    "prefix": "ok",
    "description": "Ok result",
    "body": [
      "ok(${1:value})"
    ]
  },
  "Result Err": {
    "prefix": "err",
    "description": "Error result",
    "body": [
      "err(${1:message})"
    ]
  },
  "Global Variable": {
    "prefix": "global",
    "description": "Global scope variable",
    "body": [
      "global ${1:name} := ${2:value}"
    ]
  },
  "Arena Block": {
    "prefix": "arena",
    "description": "Arena memory block",
    "body": [
      "arena ${1:name} do",
      "  ${2:body}",
      "endarena"
    ]
  },
  "Parallel Block": {
    "prefix": "parallel",
    "description": "Parallel execution block",
    "body": [
      "parallel do",
      "  ${1:task_one()}",
      "  ${2:task_two()}",
      "endparallel"
    ]
  },
  "Parallel Allowfail With Results": {
    "prefix": "parallelr",
    "description": "Parallel block with allowfail and result capture",
    "body": [
      "parallel allowfail => ${1:results} do",
      "  ${2:task_one()}",
      "  ${3:task_two()}",
      "endparallel"
    ]
  },
  "Lambda": {
    "prefix": "lambda",
    "description": "Anonymous function",
    "body": [
      "(${1:params}) => ${2:expression}"
    ]
  },
  "Write": {
    "prefix": "write",
    "description": "Write to output",
    "body": [
      "write(${1:message})"
    ]
  },
  "Tag": {
    "prefix": "tag",
    "description": "Navigation tag",
    "body": [
      "@${1:tagname}"
    ]
  }
}
