{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gwen",
  "scopeName": "source.gwen",
  "fileTypes": ["gw"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#tags"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.gwen",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.gwen"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.gwen"
            }
          }
        },
        {
          "name": "comment.line.double-slash.gwen",
          "match": "(//).*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.gwen"
            }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gwen",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gwen",
              "match": "\\\\(?:n|r|t|\\\\|\"|')"
            }
          ]
        },
        {
          "name": "string.quoted.single.gwen",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.gwen",
              "match": "\\\\(?:n|r|t|\\\\|\"|')"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.gwen",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.gwen",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.float.gwen",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.gwen",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.definition.function.gwen",
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.gwen"
            },
            "2": {
              "name": "entity.name.function.gwen"
            }
          }
        },
        {
          "name": "meta.definition.module.gwen",
          "match": "\\b(module)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.module.gwen"
            },
            "2": {
              "name": "entity.name.namespace.gwen"
            }
          }
        },
        {
          "name": "meta.definition.object.gwen",
          "match": "\\b(object)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.object.gwen"
            },
            "2": {
              "name": "entity.name.type.gwen"
            }
          }
        },
        {
          "name": "meta.definition.type.gwen",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.gwen"
            },
            "2": {
              "name": "entity.name.type.gwen"
            },
            "3": {
              "name": "keyword.operator.assignment.gwen"
            }
          }
        },
        {
          "name": "meta.import.from.gwen",
          "match": "\\b(use)\\s+([A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)\\s+(from)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.import.gwen"
            },
            "2": {
              "name": "entity.name.import.gwen"
            },
            "3": {
              "name": "keyword.declaration.import.gwen"
            },
            "4": {
              "name": "entity.name.namespace.gwen"
            }
          }
        },
        {
          "name": "meta.import.module.gwen",
          "match": "\\b(use)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b(?!\\s+from\\b)",
          "captures": {
            "1": {
              "name": "keyword.declaration.import.gwen"
            },
            "2": {
              "name": "entity.name.namespace.gwen"
            }
          }
        },
        {
          "name": "variable.language.self.gwen",
          "match": "\\bself\\b"
        },
        {
          "name": "entity.name.type.gwen",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.gwen",
          "match": "\\b(if|then|elif|else|endif|match|when|endmatch|return)\\b"
        },
        {
          "name": "keyword.control.loop.gwen",
          "match": "\\b(while|do|endwhile|for|in|to|step|with|index|order|reverse|endfor)\\b"
        },
        {
          "name": "keyword.control.parallel.gwen",
          "match": "\\b(parallel|allowfail|endparallel|arena|endarena)\\b"
        },
        {
          "name": "keyword.declaration.gwen",
          "match": "\\b(func|endfunc|module|endmodule|export|use|from|object|endobject|new|endnew|type|const|var|endvar|default|global)\\b"
        },
        {
          "name": "keyword.operator.word.gwen",
          "match": "\\b(and|or|not|mod|as)\\b"
        },
        {
          "name": "constant.language.boolean.gwen",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.result.gwen",
          "match": "\\b(ok|err)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.builtin.gwen",
          "match": "\\b(write|read|len|str|int|float|typeof|append|pop|removeat|insert|concat|sort|reversed|map|filter|range|enumerate|split|join|substring|contains|trim|replace|abs|min|max|sqrt|floor|ceil|haskey|get|keys|values|items|readfile|writefile|appendfile)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.builtin.gwen",
          "match": "\\b(asc|desc)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.gwen",
          "match": "\\b(int|float|string|bool|void)\\b"
        },
        {
          "name": "storage.type.precision.gwen",
          "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64)\\b"
        },
        {
          "name": "storage.type.precision.gwen",
          "match": "\\b(float32|float64)\\b"
        },
        {
          "name": "storage.type.generic.gwen",
          "match": "\\b(list|dict|result|money)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.gwen",
          "match": "(:=|=>|->)"
        },
        {
          "name": "keyword.operator.comparison.gwen",
          "match": "(=|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.gwen",
          "match": "(\\+|-|\\*|/|\\^)"
        }
      ]
    },
    "tags": {
      "patterns": [
        {
          "name": "entity.name.tag.gwen",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.member.gwen",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "variable.other.gwen",
          "match": "[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    }
  }
}
