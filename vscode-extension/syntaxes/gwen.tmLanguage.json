{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gwen",
  "scopeName": "source.gwen",
  "fileTypes": [".gw"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#tags"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.gwen",
          "match": "(--).*$",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.gwen"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gwen",
          "match": "\\b(if|then|elif|else|endif|while|do|endwhile|for|in|to|step|order|reverse|endfor|match|when|endmatch|return)\\b"
        },
        {
          "name": "keyword.control.gwen",
          "match": "\\b(allow_fail|parallel|section)\\b"
        },
        {
          "name": "keyword.other.endblock.gwen",
          "match": "\\b(endparallel|endsection|endarena)\\b"
        },
        {
          "name": "keyword.declaration.function.gwen",
          "match": "\\b(func|endfunc)\\b"
        },
        {
          "name": "keyword.declaration.module.gwen",
          "match": "\\b(module|endmodule|export|use|from)\\b"
        },
        {
          "name": "keyword.other.global.gwen",
          "match": "\\b(global|arena)\\b"
        },
        {
          "name": "keyword.operator.logical.gwen",
          "match": "\\b(and|or|not|mod|ok|err)\\b"
        },
        {
          "name": "keyword.constant.gwen",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "keyword.control.gwen",
          "match": "\\b(with|index)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.gwen",
          "match": "\\b(int|float|string|bool|void)\\b"
        },
        {
          "name": "storage.type.precision.gwen",
          "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64)\\b"
        },
        {
          "name": "storage.type.precision.gwen",
          "match": "\\b(float32|float64|decimal)\\b"
        },
        {
          "name": "storage.type.generic.gwen",
          "match": "\\b(list|result)\\b"
        },
        {
          "name": "keyword.cast.gwen",
          "match": "\\bas\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.gwen",
          "match": "(:=|=>|->)"
        },
        {
          "name": "keyword.operator.comparison.gwen",
          "match": "(=|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.gwen",
          "match": "(\\+|-\\*|/|\\^|//)"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.gwen",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.gwen",
              "match": "\\\\(n|t|\\\\|\"|')"
            }
          ]
        },
        {
          "name": "string.quoted.single.gwen",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.gwen",
              "match": "\\\\(n|t|\\\\|\"|')"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.decimal.gwen",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.numeric.float.gwen",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.gwen",
          "match": "\\b0x[0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.gwen",
          "match": "\\b0b[01]+\\b"
        }
      ]
    },
    "tags": {
      "patterns": [
        {
          "name": "entity.name.tag.gwen",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.gwen",
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.gwen"
            },
            "2": {
              "name": "entity.name.function.gwen"
            }
          }
        },
        {
          "name": "support.function.builtin.gwen",
          "match": "\\b(write|len|append|pop)\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.gwen",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    }
  }
}
