{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Gwen File",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd/gwen", "run", "${file}"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Check Gwen File",
      "type": "shell",
      "command": "go",
      "args": ["run", "./cmd/gwen", "check", "${file}"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
