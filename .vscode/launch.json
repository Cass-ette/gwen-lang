{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Gwen File",
      "type": "node-terminal",
      "request": "launch",
      "command": "go run ./cmd/gwen run \"${file}\"",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Check Gwen File",
      "type": "node-terminal",
      "request": "launch",
      "command": "go run ./cmd/gwen check \"${file}\"",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Build Gwen File",
      "type": "node-terminal",
      "request": "launch",
      "command": "go run ./cmd/gwen build \"${file}\"",
      "cwd": "${workspaceFolder}"
    }
  ]
}
